<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categories</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/categories">Categories</a>
        <a class="nav-link" href="/categories/new">New Category</a>
        <a class="nav-link" href="/items/new">New Item</a>
      </div>
    </nav>

    <main class="page">
      <section class="card">
        <h1>Categories</h1>
        <ul class="list">
          <% categories.forEach((category) => { %>
            <li>
              <a href="/categories/<%= category.id %>/items"><%= category.name %></a>
              <div class="actions">
                <a class="nav-link" href="/categories/<%= category.id %>/items">View Items</a>
                <a class="nav-link" href="/categories/<%= category.id %>/edit">Edit Category</a>
              </div>
            </li>
          <% }) %>
        </ul>
      </section>
    </main>
  </body>
</html>
