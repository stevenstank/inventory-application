<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Category</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/categories">Categories</a>
        <a class="nav-link" href="/categories/new">New Category</a>
        <a class="nav-link" href="/items/new">New Item</a>
      </div>
    </nav>

    <main class="page split">
      <section class="card">
        <h1>Edit Category</h1>

        <% if (typeof error !== "undefined" && error === "wrong_password") { %>
          <p class="error-message">Wrong admin password</p>
        <% } %>

        <% if (typeof error !== "undefined" && error === "has_items") { %>
          <p class="error-message">Cannot delete category with existing items</p>
        <% } %>

        <form class="form-grid" action="/categories/<%= category.id %>/edit" method="POST">
          <div>
            <label for="name">Category Name</label>
            <input id="name" name="name" type="text" value="<%= category.name %>" required />
          </div>

          <div>
            <label for="adminPassword">Admin Password</label>
            <input id="adminPassword" name="adminPassword" type="password" required />
          </div>

          <button type="submit">Update Category</button>
        </form>
      </section>

      <section class="card">
        <h2>Delete Category</h2>
        <form class="form-grid" action="/categories/<%= category.id %>/delete" method="POST">
          <div>
            <label for="deleteAdminPassword">Admin Password</label>
            <input id="deleteAdminPassword" name="adminPassword" type="password" required />
          </div>
          <button class="btn-danger" type="submit">Delete Category</button>
        </form>
      </section>
    </main>
  </body>
</html>
