<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Category</title>
  </head>
  <body>
    <h1>Edit Category</h1>

    <form action="/categories/<%= category.id %>/edit" method="POST">
      <label for="name">Category Name</label>
      <input id="name" name="name" type="text" value="<%= category.name %>" required />

      <label for="admin_password">Admin Password</label>
      <input id="admin_password" name="admin_password" type="password" required />

      <button type="submit">Update Category</button>
    </form>

    <form action="/categories/<%= category.id %>/delete" method="POST">
      <label for="delete_admin_password">Admin Password</label>
      <input id="delete_admin_password" name="admin_password" type="password" required />
      <button type="submit">Delete Category</button>
    </form>
  </body>
</html>
